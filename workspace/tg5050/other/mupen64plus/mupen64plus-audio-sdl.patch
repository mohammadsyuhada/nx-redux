diff --git a/src/sdl_backend.c b/src/sdl_backend.c
index 572aae3..c918244 100644
--- a/src/sdl_backend.c
+++ b/src/sdl_backend.c
@@ -21,6 +21,7 @@
 
 #include <SDL.h>
 #include <SDL_audio.h>
+#include <stdio.h>
 #include <stdlib.h>
 #include <string.h>
 
@@ -41,7 +42,17 @@
 #define SDL_UnlockAudio() SDL_UnlockAudioDevice(sdl_backend->device)
 #define SDL_PauseAudio(A) SDL_PauseAudioDevice(sdl_backend->device, A)
 #define SDL_CloseAudio() SDL_CloseAudioDevice(sdl_backend->device)
-#define SDL_OpenAudio(A, B) ((sdl_backend->device = SDL_OpenAudioDevice(NULL, 0, A, B, 0)) - 1)
+/* Get preferred audio device from AUDIODEV env var (set by launch script).
+ * Returns NULL for SDL default device if unset or "default". */
+static const char* get_preferred_audio_device(void)
+{
+    const char* dev = getenv("AUDIODEV");
+    if (dev && dev[0] != '\0' && strcmp(dev, "default") != 0)
+        return dev;
+    return NULL;
+}
+
+#define SDL_OpenAudio(A, B) ((sdl_backend->device = SDL_OpenAudioDevice(get_preferred_audio_device(), 0, A, B, 0)) - 1)
 struct sdl_backend
 {
     SDL_AudioDeviceID device;
